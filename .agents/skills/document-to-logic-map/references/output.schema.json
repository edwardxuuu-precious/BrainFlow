{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "document-to-logic-map/v2-output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "spec_version",
    "document_type",
    "document_type_confidence",
    "document_type_rationale",
    "summary",
    "nodes",
    "warnings"
  ],
  "properties": {
    "spec_version": {
      "const": "document-to-logic-map/v2"
    },
    "document_type": {
      "type": "string",
      "enum": ["analysis", "process", "plan", "notes"]
    },
    "document_type_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "document_type_rationale": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "parent_id",
          "order",
          "type",
          "title",
          "note",
          "semantic_role",
          "confidence",
          "source_spans",
          "structure_role",
          "locked",
          "source_module_id",
          "proposed_reorder",
          "proposed_reparent",
          "task"
        ],
        "properties": {
          "id": { "type": "string" },
          "parent_id": { "type": ["string", "null"] },
          "order": { "type": "integer" },
          "type": {
            "type": "string",
            "enum": ["section", "claim", "evidence", "task", "decision", "risk", "metric", "question"]
          },
          "title": { "type": "string" },
          "note": { "type": ["string", "null"] },
          "semantic_role": {
            "type": "string",
            "enum": ["section", "claim", "evidence", "task", "decision", "risk", "metric", "question"]
          },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "source_spans": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["line_start", "line_end"],
              "properties": {
                "line_start": { "type": "integer" },
                "line_end": { "type": "integer" }
              }
            }
          },
          "structure_role": {
            "type": ["string", "null"],
            "enum": [
              "root_context",
              "judgment_module",
              "core_judgment_group",
              "judgment_basis_group",
              "potential_action_group",
              "core_judgment",
              "basis_item",
              "action_item",
              "execution_root",
              "execution_task_mirror",
              null
            ]
          },
          "locked": { "type": "boolean" },
          "source_module_id": { "type": ["string", "null"] },
          "proposed_reorder": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "required": ["after_node_id", "reason"],
            "properties": {
              "after_node_id": { "type": ["string", "null"] },
              "reason": { "type": ["string", "null"] }
            }
          },
          "proposed_reparent": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "required": ["new_parent_id", "reason"],
            "properties": {
              "new_parent_id": { "type": ["string", "null"] },
              "reason": { "type": ["string", "null"] }
            }
          },
          "task": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "required": ["status", "output", "depends_on", "inferred_output", "mirrored_task_id"],
            "properties": {
              "status": {
                "type": "string",
                "enum": ["todo", "in_progress", "blocked", "done"]
              },
              "output": { "type": ["string", "null"] },
              "depends_on": {
                "type": "array",
                "items": { "type": "string" }
              },
              "inferred_output": { "type": "boolean" },
              "mirrored_task_id": { "type": ["string", "null"] }
            }
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
