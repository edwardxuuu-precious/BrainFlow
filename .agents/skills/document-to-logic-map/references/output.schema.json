{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "document-to-logic-map/v1-output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "spec_version",
    "document_type",
    "document_type_confidence",
    "document_type_rationale",
    "summary",
    "nodes",
    "warnings"
  ],
  "properties": {
    "spec_version": {
      "const": "document-to-logic-map/v1"
    },
    "document_type": {
      "type": "string",
      "enum": ["analysis", "process", "plan", "notes"]
    },
    "document_type_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "document_type_rationale": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "parent_id",
          "order",
          "type",
          "title",
          "note",
          "semantic_role",
          "confidence",
          "source_spans"
        ],
        "properties": {
          "id": { "type": "string" },
          "parent_id": { "type": ["string", "null"] },
          "order": { "type": "integer" },
          "type": {
            "type": "string",
            "enum": ["section", "claim", "evidence", "task", "decision", "risk", "metric", "question"]
          },
          "title": { "type": "string" },
          "note": { "type": ["string", "null"] },
          "semantic_role": {
            "type": "string",
            "enum": ["section", "claim", "evidence", "task", "decision", "risk", "metric", "question"]
          },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "source_spans": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["line_start", "line_end"],
              "properties": {
                "line_start": { "type": "integer" },
                "line_end": { "type": "integer" }
              }
            }
          },
          "task": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "required": ["status", "output"],
            "properties": {
              "status": {
                "type": "string",
                "enum": ["todo", "in_progress", "blocked", "done"]
              },
              "output": { "type": ["string", "null"] }
            }
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
