AI_SERVER_PORT=8787
BRAINFLOW_SYSTEM_PROMPT_FILE=server/prompts/brainflow-system.md
BRAINFLOW_AI_SETTINGS_FILE=

# ============================================
# AI Provider 配置
# 可选: codex | deepseek | kimi
# ============================================
BRAINFLOW_AI_PROVIDER=codex

# --- DeepSeek 配置 ---
# 获取 API Key: https://platform.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Kimi (Moonshot AI) 配置 ---
# 获取 API Key: https://platform.moonshot.cn/
KIMI_API_KEY=
KIMI_MODEL=moonshot-v1-32k
# KIMI_BASE_URL=https://api.moonshot.cn

# ============================================
# 认证配置
# ============================================
BRAINFLOW_AUTH_MODE=external
BRAINFLOW_STUB_USER_ID=user_stub_default
BRAINFLOW_SESSION_SECRET=replace-with-a-long-random-secret
BRAINFLOW_ADMIN_USERNAME=admin
BRAINFLOW_ADMIN_PASSWORD_HASH=
BRAINFLOW_SESSION_TTL_SECONDS=2592000

# ============================================
# 数据库配置
# ============================================
BRAINFLOW_SYNC_DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/brainflow
BRAINFLOW_SYNC_DATABASE_SSL=false
BRAINFLOW_SYNC_PULL_LIMIT=200

# ============================================
# 其他配置
# ============================================
BRAINFLOW_CANONICAL_ORIGIN=http://127.0.0.1:4173
BRAINFLOW_POSTGRES_BACKUP_DIR=backups/postgres
BRAINFLOW_POSTGRES_BACKUP_FORMAT=custom
BRAINFLOW_POSTGRES_BACKUP_CONTAINER=brainflow-postgres
